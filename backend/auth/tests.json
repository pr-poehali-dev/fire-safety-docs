{
  "tests": [
    {
      "name": "Get roles",
      "method": "GET",
      "path": "/?action=roles",
      "expectedStatus": 200
    },
    {
      "name": "Get password rules",
      "method": "GET",
      "path": "/?action=password_rules",
      "expectedStatus": 200,
      "expectedBody": {"min_length": 12},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get all objects",
      "method": "GET",
      "path": "/?action=objects",
      "expectedStatus": 200
    },
    {
      "name": "Reject weak password",
      "method": "POST",
      "path": "/",
      "body": {
        "action": "register",
        "email": "weakpw@test.com",
        "password": "123",
        "full_name": "Test",
        "role": "responsible"
      },
      "expectedStatus": 400
    },
    {
      "name": "Get auth logs",
      "method": "GET",
      "path": "/?action=auth_logs&limit=5",
      "expectedStatus": 200
    }
  ]
}
